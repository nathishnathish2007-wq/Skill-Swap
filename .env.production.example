NODE_ENV=production
PORT=5000
DATA_MODE=mongo
SEED_DEMO_DATA=true

# Comma-separated list is supported.
CLIENT_URL=https://your-skillswap-app.onrender.com

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/skillswap?retryWrites=true&w=majority
JWT_SECRET=replace_this_with_a_long_random_secret
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@skillswap.com
